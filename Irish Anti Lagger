local function LoadConfig()
    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile("IrishHub_AntiLag_Config.json"))
    end)
    if success and data then
        CONFIG = data
    end
end

local function SaveConfig()
    pcall(function()
        writefile("IrishHub_AntiLag_Config.json", HttpService:JSONEncode(CONFIG))
    end)
end

